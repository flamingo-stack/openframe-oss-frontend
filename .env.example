# OpenFrame React Frontend Environment Variables

# DevTicket Observer
# Enable/disable the global DevTicket observer for SSO authentication
# Set to 'true' to enable automatic devTicket detection and exchange
NEXT_PUBLIC_ENABLE_DEV_TICKET_OBSERVER=false

# Authentication Check Interval
# How often to check authentication status (in milliseconds)
# Default: 60000 (1 minute)
NEXT_PUBLIC_AUTH_CHECK_INTERVAL=60000

# 'oss-tenant' | 'saas-tenant' | 'saas-shared'
NEXT_PUBLIC_APP_MODE=oss-tenant

NEXT_PUBLIC_GTM_CONTAINER_ID=

# Feature Flags
# Script Schedule feature - enables script scheduling functionality
NEXT_PUBLIC_FEATURE_SCRIPT_SCHEDULE=false

# PR Number field on the signup form - links registrations to a git PR for testing
# Enable on dev environments only; keep disabled on stage and prod
NEXT_PUBLIC_PR_NUMBER_ENABLED=false

# Guide-mode chat proxy (server-only — intentionally NOT NEXT_PUBLIC_)
# Origin (no path) of the multi-platform-hub chat backend that the /api/guide-chat/* routes forward to
HUB_CHAT_BASE_URL=
# Server-held service token sent as x-chat-service-token; the hub waives chat auth with a 'service' tier for it
CHAT_SERVICE_TOKEN=

# Visitor-IP trust for the guide-chat proxy. The hub trusts the x-chat-ip we
# forward, so a vendor header is only read where something on the request path
# actually OVERWRITES it; otherwise it arrives verbatim from the client and each
# visitor can mint their own rate-limit bucket. Unset both and the proxy falls
# back to the LAST x-forwarded-for hop alone.
# Set automatically by the Vercel runtime — enables reading x-vercel-forwarded-for.
# VERCEL=1
# Set to any non-empty value ONLY when the ingress in front of this app sets
# X-Real-IP itself (nginx: `proxy_set_header X-Real-IP $remote_addr`).
TRUSTED_INGRESS_SETS_REAL_IP=
